# Copy to .env and adjust for your environment.
# Vite only exposes variables that start with VITE_.

# Base URL of the FastAPI backend, including the /api prefix (no trailing slash).
# Used by: AdMasters, SongMasters, Broadcasts, Login, upload modals, WaveformModal.
#
# Local (default backend port 8000):
VITE_API_URL=http://localhost:8000/api

# Production example:
# VITE_API_URL=https://your-api.example.com/api
